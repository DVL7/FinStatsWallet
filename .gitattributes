# Normalize line endings across OSes
* text=auto eol=lf

# Windows-native scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix-native scripts
*.sh text eol=lf

# Keep binaries untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.exe binary
